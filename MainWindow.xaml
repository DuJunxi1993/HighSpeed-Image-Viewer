<ui:FluentWindow x:Class="HighSpeedImageViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HighSpeedImageViewer.Controls"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="HighSpeed Image Viewer"
        Width="1400" Height="900"
        WindowStartupLocation="CenterScreen"
        Foreground="White"
        TextOptions.TextFormattingMode="Display"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        KeyboardNavigation.DirectionalNavigation="None"
        WindowBackdropType="None"
        Background="#1E1E1E"
        AllowDrop="True">

    <Window.Resources>
        <Style x:Key="OpenButton" TargetType="Button">
            <Setter Property="Background" Value="#0067C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ModernButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#4A4A4A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="#0067C0"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#0078D4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WindowButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D3D"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#505050"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button" BasedOn="{StaticResource WindowButton}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C42B1C"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#B22A1B"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="TitleBarRow" Height="48"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" x:Name="TitleBarArea" Background="#1E1E1E" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0">
                    <Button Style="{StaticResource OpenButton}" Click="BtnOpen_Click" ToolTip="Ctrl+O" Padding="12,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📂" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="打开" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ModernButton}" Click="BtnSidePanel_Click" ToolTip="Ctrl+Shift+P" Padding="10,6" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="☰" FontSize="14" Margin="0,0,6,0"/>
                            <TextBlock Text="侧栏" FontSize="12"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock Grid.Column="1" Text="HighSpeed Image Viewer" VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="#888888" FontSize="12" FontWeight="SemiBold"/>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Style="{StaticResource WindowButton}" Click="BtnMinimize_Click">
                        <TextBlock Text="─" FontSize="12" Foreground="White"/>
                    </Button>
                    <Button x:Name="BtnMaximize" Style="{StaticResource WindowButton}" Click="BtnMaximize_Click">
                        <TextBlock x:Name="MaximizeIcon" Text="□" FontSize="12" Foreground="White"/>
                    </Button>
                    <Button Style="{StaticResource CloseButton}" Click="BtnClose_Click">
                        <TextBlock Text="✕" FontSize="12" Foreground="White"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SideColumn" Width="0"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" x:Name="SidePanelBorder" Background="#1E1E1E" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="文件列表" Foreground="#888888" FontSize="12" FontWeight="SemiBold"
                               Margin="16,12,16,8"/>
                    <ScrollViewer Grid.Row="1" x:Name="SideScroll" VerticalScrollBarVisibility="Auto">
                        <controls:ThumbnailPanel x:Name="SidePanel">
                            <controls:ThumbnailPanel.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Border x:Name="SelectionIndicator" Grid.Column="0" Background="#0067C0" Width="4"
                                                Margin="0,2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=controls:FileListItem}}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{Binding FileName}"
                                                   Foreground="#E0E0E0"
                                                   FontSize="13"
                                                   FontFamily="Segoe UI"
                                                   Padding="12,10"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTip="{Binding FileName}">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=controls:FileListItem}}" Value="True">
                                                            <Setter Property="Background" Value="#252525"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </controls:ThumbnailPanel.ItemTemplate>
                            <controls:ThumbnailPanel.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel IsItemsHost="True" />
                                </ItemsPanelTemplate>
                            </controls:ThumbnailPanel.ItemsPanel>
                            <controls:ThumbnailPanel.ItemContainerStyle>
                                <Style TargetType="controls:FileListItem">
                                    <Setter Property="Cursor" Value="Hand"/>
                                </Style>
                            </controls:ThumbnailPanel.ItemContainerStyle>
                        </controls:ThumbnailPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <Border Grid.Column="1" Background="#1E1E1E" ClipToBounds="True">
                <controls:SkiaImageViewer x:Name="ImageViewer">
                    <controls:SkiaImageViewer.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="复制图片路径" Click="CtxCopyPath_Click"/>
                            <MenuItem Header="在资源管理器中打开" Click="CtxOpenInExplorer_Click"/>
                            <MenuItem Header="打印" Click="CtxPrint_Click"/>
                            <MenuItem Header="设为桌面壁纸" Click="CtxSetWallpaper_Click"/>
                        </ContextMenu>
                    </controls:SkiaImageViewer.ContextMenu>
                </controls:SkiaImageViewer>
            </Border>
        </Grid>

        <Border Grid.Row="2" x:Name="BottomBar" Background="#1E1E1E" Padding="12,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" MinWidth="280">
                    <TextBlock x:Name="StatusText" Text="就绪" VerticalAlignment="Center" FontSize="12" Foreground="#888888"/>
                    <TextBlock x:Name="ImageInfo" Text="" VerticalAlignment="Center" FontSize="12" Foreground="#666666" Margin="20,0,0,0"/>
                    <TextBlock x:Name="ImageIndexInfo" Text="" VerticalAlignment="Center" FontSize="12" Foreground="#555555" Margin="16,0,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource NavButton}" x:Name="BtnPrev" Click="BtnPrev_Click" ToolTip="上一张 (←)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◀" FontSize="11" Foreground="White"/>
                            <TextBlock Text="上一张" FontSize="12" Foreground="White" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" x:Name="BtnNext" Click="BtnNext_Click" Margin="4,0,0,0" ToolTip="下一张 (→)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="下一张" FontSize="12" Foreground="White"/>
                            <TextBlock Text="▶" FontSize="11" Foreground="White" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal">
                    <Button Style="{StaticResource ModernButton}" Click="BtnFit_Click" Padding="10,6" ToolTip="适应 (Ctrl+0)">
                        <TextBlock Text="适应" FontSize="12"/>
                    </Button>
                    <TextBlock x:Name="ZoomTextBlock" Text="100%" Foreground="White" FontSize="12"
                               VerticalAlignment="Center" Margin="12,0" MinWidth="50" TextAlignment="Center"
                               MouseLeftButtonUp="ZoomTextBlock_Click" Cursor="Hand"/>
                    <Border Width="1" Background="#404040" Margin="8,4"/>
                    <Button x:Name="BtnSlideshow" Style="{StaticResource ModernButton}" Click="BtnSlideshow_Click" Padding="10,6" ToolTip="幻灯片 (F5)">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="SlideshowIcon" Text="▶" FontSize="11"/>
                            <TextBlock x:Name="SlideshowText" Text="幻灯片" FontSize="12" Margin="6,0,0,0"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="BtnFullscreen" Style="{StaticResource ModernButton}" Click="BtnFullscreen_Click" Padding="10,6" Margin="4,0,0,0" ToolTip="全屏 (Ctrl+F)">
                        <TextBlock Text="⛶" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</ui:FluentWindow>